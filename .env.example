# ─────────────────────────────────────────────
# API Fault Checker — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Slack ──────────────────────────────────────
# Get from: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#incidents
SLACK_MENTION_ON_P0=@oncall

# ── PagerDuty ──────────────────────────────────
# Get from: PagerDuty → Services → Integrations → Events API v2
PAGERDUTY_INTEGRATION_KEY=your_pagerduty_integration_key_here

# ── Email (optional) ───────────────────────────
# Uses Gmail SMTP — create an App Password at myaccount.google.com/apppasswords
EMAIL_ENABLED=false
EMAIL_FROM=alerts@yourcompany.com
EMAIL_TO=oncall@yourcompany.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# ── Thresholds ─────────────────────────────────
LATENCY_WARN_MS=300
LATENCY_CRIT_MS=1000
ERROR_RATE_WARN_PERCENT=1
ERROR_RATE_CRIT_PERCENT=5
TIMEOUT_MS=10000

# ── Polling ────────────────────────────────────
# Cron format: "*/1 * * * *" = every minute
POLL_CRON=*/1 * * * *
ALERT_COOLDOWN_MINUTES=10

# ── Dashboard ──────────────────────────────────
DASHBOARD_PORT=3000
DASHBOARD_ENABLED=true
